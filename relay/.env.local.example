# Local-only credentials — never committed (copy this file to .env.local and fill in real values)
TEST_ADMIN_USERNAME=your_admin_username
TEST_ADMIN_PASSWORD=your_admin_password_min_12_chars

# Required secrets (set strong random values, min 24 chars each)
RELAY_JOIN_TOKEN_SECRET=replace_with_long_random_secret_1
INVITE_TOKEN_SECRET=replace_with_long_random_secret_2
AUTH_TOKEN_SECRET=replace_with_long_random_secret_3

# Production recommendation (do not use wildcard in production)
# ALLOWED_ORIGINS=https://midimyface.com,https://www.midimyface.com
